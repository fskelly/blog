---
const { slug, title, tags, categories, description, date } = Astro.props;
---

<li class="post">
	<a href={`${import.meta.env.BASE_URL}/post/${slug}/`} class="title">{title}</a>
	<time datetime={date}>
		{
			new Date(date).toLocaleDateString("en-us", {
				year: "numeric",
				month: "short",
				day: "numeric",
			})
		}
	</time>
	<br />
	{description && <span class="excerpt">{description}</span>}
	<div>
		{
			categories &&
				categories.map((category) => (
					<a class="tag" href={`${import.meta.env.BASE_URL}/category/${category}`}>
						@{category}
					</a>
				))
		}
		{
			tags &&
				tags.map((tag) => (
					<a class="tag" href={`${import.meta.env.BASE_URL}/tag/${tag}`}>
						#{tag}
					</a>
				))
		}
	</div>
</li>
