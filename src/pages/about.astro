---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Authors from "../components/Authors.astro";
import ColorScript from "../components/ColorScript.astro";
---

<html lang="en-us">
	<BaseHead title="About" description="Meet the authors behind this blog" />
	<body>
		<Header />
		<main>
			<article class="about-page">
				<h1>About</h1>
				<Authors />
			</article>
		</main>
		<Footer />
		<ColorScript />
	</body>
</html>

<style>
	.about-page {
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	.about-page h1 {
		font-size: 2.5rem;
		margin-bottom: 2rem;
		line-height: 1.2;
	}
</style>
