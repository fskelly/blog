---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ColorScript from "../components/ColorScript.astro";

let { title, description } = Astro.props.frontmatter || Astro.props;
---

<html lang="en-us">
	<BaseHead title={title} description={description} />

	<body>
		<Header />
		<main>
			<article>
				<h1 class="article-title">{title}</h1>
				<div class="blog-post">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<ColorScript />
	</body>
</html>

<style>
	article {
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	.article-title {
		font-size: 2.5rem;
		margin-bottom: 1rem;
		line-height: 1.2;
	}

	.blog-post {
		line-height: 1.6;
		color: var(--text-color, inherit);
	}

	.blog-post :global(p) {
		margin-bottom: 1rem;
	}

	.blog-post :global(a) {
		color: var(--accent-color, #0066cc);
		text-decoration: none;
		border-bottom: 1px solid var(--accent-color, #0066cc);
	}

	.blog-post :global(a:hover) {
		opacity: 0.8;
	}
</style>
